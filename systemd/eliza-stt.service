[Unit]
Description=Eliza STT Endpoint
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
WorkingDirectory=%h/private/eliza-inference
ExecStart=%h/private/eliza-inference/scripts/start stt --profile stt-faster-whisper-small-cpu
ExecStop=%h/private/eliza-inference/scripts/stop stt --profile stt-faster-whisper-small-cpu
Restart=on-failure

[Install]
WantedBy=default.target
