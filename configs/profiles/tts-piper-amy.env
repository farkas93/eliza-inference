SERVICE_NAME="tts"
BACKEND="piper"
MODEL_NAME="piper-amy-medium"
MODEL_REPO="rhasspy/piper-voices"
MODEL_DIR="$MODEL_HOME/tts/piper-voices"
MODEL_FILE="en_US-amy-medium.onnx"
MODEL_CONFIG_FILE="en_US-amy-medium.onnx.json"
HF_INCLUDE_MODEL="en/en_US/amy/medium/en_US-amy-medium.onnx"
HF_INCLUDE_CONFIG="en/en_US/amy/medium/en_US-amy-medium.onnx.json"
PIPER_VOICE_PATH="$MODEL_DIR/en/en_US/amy/medium/$MODEL_FILE"
PIPER_CONFIG_PATH="$MODEL_DIR/en/en_US/amy/medium/$MODEL_CONFIG_FILE"
HOST="${DEFAULT_HOST:-0.0.0.0}"
PORT="${TTS_PORT:-8012}"
VOICE="amy"
