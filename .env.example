# Global defaults for local DGX Spark inference services.
# Copy to .env and edit if needed.

MODEL_HOME="$HOME/models"
HF_HOME="$MODEL_HOME/huggingface"
LLAMA_CACHE="$MODEL_HOME/llama"
LOG_DIR="$PWD/logs"

# Services bind to LAN by default. Do not expose these ports to the public internet.
DEFAULT_HOST="0.0.0.0"
QWEN_CODER_PORT="8001"
VOICE_LLM_PORT="8002"
STT_PORT="8011"
TTS_PORT="8012"
VOCODE_BRIDGE_PORT="8021"

# Optional explicit binary paths.
VLLM_BIN="vllm"
LLAMA_SERVER_BIN="llama-server"
PIPER_BIN="piper"

# Vocode or other orchestrators can use these URLs.
STT_BASE_URL="http://127.0.0.1:8011/v1"
VOICE_LLM_BASE_URL="http://127.0.0.1:8002/v1"
TTS_BASE_URL="http://127.0.0.1:8012/v1"
VOCODE_BRIDGE_BASE_URL="ws://127.0.0.1:8021/ws"
