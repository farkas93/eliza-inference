#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/common.sh"
load_env

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<USAGE
Usage: ./scripts/setup vocode

Installs Vocode bridge transport dependencies into .venvs/vocode and verifies package imports.

Note: this bridge spike does not install the vocode package yet. The current service validates
browser audio transport through hosted STT/TTS endpoints before deeper Vocode internals are added.
USAGE
  exit 0
fi

if ! command -v uv >/dev/null 2>&1; then
  echo "uv is required. Run ./scripts/setup prerequisites first." >&2
  exit 1
fi

ensure_venv "$VOCODE_VENV"
uv pip install --python "$VOCODE_VENV/bin/python" -U \
  "fastapi>=0.115.0" \
  "uvicorn[standard]>=0.34.0" \
  "websockets>=13.0"

"$VOCODE_VENV/bin/python" - <<'PY'
import importlib.metadata as md
for package in ("fastapi", "uvicorn", "websockets"):
    try:
        print(f"{package}={md.version(package)}")
    except md.PackageNotFoundError:
        raise SystemExit(f"{package} did not install")
PY

cat <<'EOF'

Vocode bridge transport dependencies installed.

The current vocode-bridge service validates browser audio transport and hosted STT/TTS endpoints first.
The vocode package is intentionally deferred because current vocode releases constrain websockets <13.
Deeper Vocode StreamingConversation adapters can be added once this bridge contract is proven.
EOF
