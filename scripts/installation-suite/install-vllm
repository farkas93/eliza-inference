#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/common.sh"
load_env

INSTALL_VLLM="true"
VLLM_PACKAGE="vllm"
UV_TORCH_BACKEND="auto"
EXTRA_UV_PIP_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-install)
      INSTALL_VLLM="false"
      shift
      ;;
    --pre)
      EXTRA_UV_PIP_ARGS+=(--pre)
      shift
      ;;
    --package)
      VLLM_PACKAGE="${2:-}"
      shift 2
      ;;
    --torch-backend)
      UV_TORCH_BACKEND="${2:-}"
      shift 2
      ;;
    --index-url)
      EXTRA_UV_PIP_ARGS+=(--index-url "${2:-}")
      shift 2
      ;;
    --extra-index-url)
      EXTRA_UV_PIP_ARGS+=(--extra-index-url "${2:-}")
      shift 2
      ;;
    -h|--help)
      cat <<USAGE
Usage: ./scripts/setup vllm [options]

Installs and verifies vLLM for GPU serving.

Options:
  --no-install              Skip installation and only run verification.
  --pre                     Allow pre-release packages.
  --package PACKAGE         vLLM package spec to install. Default: vllm
  --torch-backend BACKEND   uv torch backend. Default: auto
  --index-url URL           Pass an index URL to uv pip install.
  --extra-index-url URL     Pass an extra index URL to uv pip install.
USAGE
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

require_uv() {
  if ! command -v uv >/dev/null 2>&1; then
    echo "uv is required. Run ./scripts/setup prerequisites first." >&2
    exit 1
  fi
}

show_host_gpu() {
  if command -v nvidia-smi >/dev/null 2>&1; then
    echo "Host GPU:"
    nvidia-smi --query-gpu=name,driver_version,memory.total --format=csv,noheader || true
  else
    echo "[warn] nvidia-smi is not available; GPU verification will rely on torch only" >&2
  fi
}

install_vllm() {
  ensure_venv "$VLLM_VENV"

  if [[ "$INSTALL_VLLM" == "true" ]]; then
    echo "Installing vLLM package into $VLLM_VENV: $VLLM_PACKAGE"
    uv pip install --python "$VLLM_VENV/bin/python" -U "$VLLM_PACKAGE" --torch-backend="$UV_TORCH_BACKEND" "${EXTRA_UV_PIP_ARGS[@]}"
    echo "Installing vLLM runtime build helpers into $VLLM_VENV"
    uv pip install --python "$VLLM_VENV/bin/python" -U "ninja>=1.11"
  else
    echo "Skipping vLLM install (--no-install)."
  fi
}

verify_native_build_prereqs() {
  if ! command -v gcc >/dev/null 2>&1; then
    echo "Missing required native compiler: gcc" >&2
    echo "Install build prerequisites, for example: sudo apt-get install -y build-essential python3-dev" >&2
    exit 1
  fi

  if [[ ! -x "$VLLM_VENV/bin/ninja" ]]; then
    echo "Missing ninja in vLLM environment: $VLLM_VENV/bin/ninja" >&2
    echo "Run ./scripts/setup vllm to install FlashInfer/vLLM JIT build helpers." >&2
    exit 1
  fi

  "$VLLM_VENV/bin/python" - <<'PY'
from __future__ import annotations

import os
import sys
import sysconfig

include_dir = sysconfig.get_path("include")
python_h = os.path.join(include_dir or "", "Python.h")
package = f"python{sys.version_info.major}.{sys.version_info.minor}-dev"

print("Native build prerequisites:")
print(f"  include_dir={include_dir}")
print(f"  Python.h={python_h}")

if not include_dir or not os.path.exists(python_h):
    raise SystemExit(
        "Missing Python development headers required by Triton/vLLM runtime compilation.\n"
        f"Install them with: sudo apt-get install -y build-essential {package}"
    )

print("  Python.h=present")
PY
}

verify_python_runtime() {
  "$VLLM_VENV/bin/python" - <<'PY'
from __future__ import annotations

import importlib.metadata as md
import platform
import shutil
import subprocess
import sys

print("Python runtime:")
print(f"  executable={sys.executable}")
print(f"  version={sys.version.split()[0]}")
print(f"  platform={platform.platform()}")
print(f"  machine={platform.machine()}")

print("\nPackage versions:")
for package in ("torch", "vllm", "transformers", "tokenizers", "triton", "xformers", "ninja"):
    try:
        print(f"  {package}={md.version(package)}")
    except md.PackageNotFoundError:
        print(f"  {package}=not-installed")

try:
    import torch
except Exception as exc:  # pragma: no cover - install-time diagnostic
    raise SystemExit(f"Failed to import torch: {exc}") from exc

print("\nTorch CUDA:")
print(f"  torch.version.cuda={torch.version.cuda}")
cuda_available = torch.cuda.is_available()
print(f"  torch.cuda.is_available={cuda_available}")
if not cuda_available:
    raise SystemExit("torch CUDA is not available; vLLM is not ready for GPU serving")

device_count = torch.cuda.device_count()
print(f"  torch.cuda.device_count={device_count}")
for index in range(device_count):
    props = torch.cuda.get_device_properties(index)
    print(f"  device.{index}.name={props.name}")
    print(f"  device.{index}.capability={props.major}.{props.minor}")
    print(f"  device.{index}.total_memory_gb={props.total_memory / 1024**3:.2f}")

try:
    import vllm
except Exception as exc:  # pragma: no cover - install-time diagnostic
    raise SystemExit(f"Failed to import vllm: {exc}") from exc

print("\nvLLM import: ok")
vllm_cli = shutil.which("vllm")
print(f"vllm CLI on PATH: {vllm_cli or 'not-found-in-shell-path'}")
ninja_cli = shutil.which("ninja")
print(f"ninja CLI on PATH: {ninja_cli or 'not-found-in-shell-path'}")
if not ninja_cli:
    raise SystemExit("ninja is required for FlashInfer/vLLM JIT compilation and is not on PATH")

try:
    completed = subprocess.run(
        [sys.executable, "-m", "vllm.entrypoints.openai.api_server", "--help"],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        timeout=30,
    )
    print(f"vLLM OpenAI server module help exit_code={completed.returncode}")
except Exception as exc:
    print(f"vLLM OpenAI server module help check failed: {exc}")
PY
}

verify_vllm_cli() {
  if "$VLLM_VENV/bin/vllm" --help >/dev/null 2>&1; then
    echo "[ok] vllm CLI works at $VLLM_VENV/bin/vllm"
  else
    echo "[warn] vllm CLI did not run from $VLLM_VENV; module-based serving may still work" >&2
  fi
}

require_uv
show_host_gpu
install_vllm
verify_native_build_prereqs
verify_python_runtime
verify_vllm_cli

cat <<'EOF'


Next low-risk serving check:
  ./scripts/start eliza-small --profile small/gemma4-e4b-vllm-8k
  ./scripts/smoke-test eliza-small --profile small/gemma4-e4b-vllm-8k

Then test Qwen conservatively:
  ./scripts/start eliza-medium --profile medium/qwen3_6-27b-fp8-vllm-8k
  ./scripts/smoke-test eliza-medium --profile medium/qwen3_6-27b-fp8-vllm-8k
EOF
