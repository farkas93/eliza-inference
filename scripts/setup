#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SUITE_DIR="$ROOT_DIR/scripts/installation-suite"

print_manual() {
  cat <<'USAGE'
Usage: ./scripts/setup <command> [args]

Commands:
  prerequisites           Install base prerequisites and .venvs/base
  llamacpp [options]      Build/install llama.cpp CUDA binaries
  stt [options]           Install STT runtime and verify profile
  tts [options]           Install TTS runtime and verify profile
  vllm [options]          Install vLLM runtime and verify GPU stack
  vocode [options]        Install vocode bridge dependencies
  clean-system [options]  Run full setup chain for a clean machine

Examples:
  ./scripts/setup prerequisites
  ./scripts/setup llamacpp --clean
  ./scripts/setup stt --profile stt/faster-whisper-small-cpu
  ./scripts/setup tts --profile tts/piper-lessac
  ./scripts/setup clean-system
  ./scripts/setup clean-system --with-vllm

Use './scripts/setup <command> --help' for command-specific options.
USAGE
}

if [[ $# -eq 0 ]]; then
  print_manual
  exit 0
fi

case "$1" in
  -h|--help)
    print_manual
    exit 0
    ;;
  prerequisites)
    shift
    exec "$SUITE_DIR/install-prerequisites" "$@"
    ;;
  llamacpp)
    shift
    exec "$SUITE_DIR/install-llamacpp" "$@"
    ;;
  stt)
    shift
    exec "$SUITE_DIR/install-stt" "$@"
    ;;
  tts)
    shift
    exec "$SUITE_DIR/install-tts" "$@"
    ;;
  vllm)
    shift
    exec "$SUITE_DIR/install-vllm" "$@"
    ;;
  vocode)
    shift
    exec "$SUITE_DIR/install-vocode" "$@"
    ;;
  clean-system)
    shift
    exec "$SUITE_DIR/setup-clean-system" "$@"
    ;;
  *)
    echo "Unknown setup command: $1" >&2
    echo "Run './scripts/setup --help' for usage." >&2
    exit 2
    ;;
esac
