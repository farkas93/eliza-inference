#!/usr/bin/env bash
set -euo pipefail

COMMAND_NAME="benchmark-context"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/common.sh"
load_env

SERVICE="${1:-}"
shift || true
PROFILE=""
TOKENS="8192"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      PROFILE="${2:-}"
      shift 2
      ;;
    --tokens)
      TOKENS="${2:-}"
      shift 2
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

set -- "$SERVICE"
if [[ -n "$PROFILE" ]]; then
  set -- "$SERVICE" --profile "$PROFILE"
fi
parse_service_profile "$@"

base_url="$(service_base_url)"
model="$(service_model_name)"
timestamp="$(date +%Y%m%d-%H%M%S)"
output="$ROOT_DIR/benchmarks/results/${SERVICE}-${PROFILE:-default}-${TOKENS}-${timestamp}.json"

if [[ ! -x "$BASE_VENV/bin/python" ]]; then
  echo "Base venv missing. Run ./scripts/install first." >&2
  exit 1
fi

"$BASE_VENV/bin/python" "$ROOT_DIR/clients/openai/long_context_test.py" \
  --base-url "$base_url" \
  --model "$model" \
  --tokens "$TOKENS" \
  --output-json "$output"

echo "Saved benchmark: $output"
