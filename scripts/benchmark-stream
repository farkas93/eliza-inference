#!/usr/bin/env bash
set -euo pipefail

COMMAND_NAME="benchmark-stream"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/common.sh"
load_env

SERVICE="${1:-}"
if [[ "$SERVICE" == "-h" || "$SERVICE" == "--help" ]]; then
  cat <<USAGE
Usage: ./scripts/benchmark-stream <service> [--profile <profile-name>] [options]

Options:
  --max-tokens <n>       Completion token cap (default: 256)
  --context-tokens <n>   Add approximate synthetic context before prompt
  --prompt <text>        Prompt to send
  --prompt-file <path>   Read prompt from file
  --show-raw             Print raw SSE events before the JSON summary
  --show-deltas          Print parsed content/reasoning deltas

Examples:
  ./scripts/benchmark-stream eliza-medium --profile eliza-medium-qwen-llamacpp-32k --show-raw
  ./scripts/benchmark-stream eliza-medium --profile eliza-medium-qwen36-35b-a3b-llamacpp-200k-experimental --max-tokens 1024
USAGE
  exit 0
fi
shift || true
PROFILE=""
MAX_TOKENS="256"
CONTEXT_TOKENS="0"
PROMPT=""
PROMPT_FILE=""
SHOW_RAW="false"
SHOW_DELTAS="false"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      PROFILE="${2:-}"
      shift 2
      ;;
    --max-tokens)
      MAX_TOKENS="${2:-}"
      shift 2
      ;;
    --context-tokens)
      CONTEXT_TOKENS="${2:-}"
      shift 2
      ;;
    --prompt)
      PROMPT="${2:-}"
      shift 2
      ;;
    --prompt-file)
      PROMPT_FILE="${2:-}"
      shift 2
      ;;
    --show-raw)
      SHOW_RAW="true"
      shift
      ;;
    --show-deltas)
      SHOW_DELTAS="true"
      shift
      ;;
    -h|--help)
      cat <<USAGE
Usage: ./scripts/benchmark-stream <service> [--profile <profile-name>] [options]

Options:
  --max-tokens <n>       Completion token cap (default: 256)
  --context-tokens <n>   Add approximate synthetic context before prompt
  --prompt <text>        Prompt to send
  --prompt-file <path>   Read prompt from file
  --show-raw             Print raw SSE events before the JSON summary
  --show-deltas          Print parsed content/reasoning deltas

Examples:
  ./scripts/benchmark-stream eliza-medium --profile eliza-medium-qwen-llamacpp-32k --show-raw
  ./scripts/benchmark-stream eliza-medium --profile eliza-medium-qwen36-35b-a3b-llamacpp-200k-experimental --max-tokens 1024
USAGE
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

set -- "$SERVICE"
if [[ -n "$PROFILE" ]]; then
  set -- "$SERVICE" --profile "$PROFILE"
fi
parse_service_profile "$@"

base_url="$(service_base_url)"
model="$(service_model_name)"
timestamp="$(date +%Y%m%d-%H%M%S)"
output="$ROOT_DIR/benchmarks/results/${SERVICE}-${PROFILE:-default}-stream-${timestamp}.json"

if [[ ! -x "$BASE_VENV/bin/python" ]]; then
  echo "Base venv missing. Run ./scripts/install first." >&2
  exit 1
fi

args=(
  --base-url "$base_url"
  --model "$model"
  --max-tokens "$MAX_TOKENS"
  --context-tokens "$CONTEXT_TOKENS"
  --output-json "$output"
)

if [[ -n "$PROMPT" ]]; then
  args+=(--prompt "$PROMPT")
fi
if [[ -n "$PROMPT_FILE" ]]; then
  args+=(--prompt-file "$PROMPT_FILE")
fi
if [[ "$SHOW_RAW" == "true" ]]; then
  args+=(--show-raw)
fi
if [[ "$SHOW_DELTAS" == "true" ]]; then
  args+=(--show-deltas)
fi

"$BASE_VENV/bin/python" "$ROOT_DIR/clients/openai/stream_inspect.py" "${args[@]}"

echo "Saved benchmark: $output"
