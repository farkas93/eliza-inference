#!/usr/bin/env bash
set -euo pipefail

COMMAND_NAME="status"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/common.sh"
load_env
parse_service_profile "$@"
source_profile

if command -v tmux >/dev/null 2>&1 && tmux_has_session; then
  echo "running: $SERVICE ($SESSION_NAME)"
else
  echo "stopped: $SERVICE ($SESSION_NAME)"
fi

if [[ -x "$SERVICE_DIR/healthcheck.sh" ]]; then
  "$SERVICE_DIR/healthcheck.sh" || true
fi
