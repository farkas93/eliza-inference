#!/usr/bin/env bash
set -euo pipefail

COMMAND_NAME="smoke-test"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/scripts/lib/common.sh"
load_env
parse_service_profile "$@"

if [[ ! -x "$BASE_VENV/bin/python" ]]; then
  echo "Base venv missing. Run ./scripts/install first." >&2
  exit 1
fi

case "$SERVICE" in
  stt)
    base_url="$(service_base_url)"
    model="$(service_model_name)"
    "$BASE_VENV/bin/python" "$ROOT_DIR/clients/audio/stt_test.py" \
      --base-url "$base_url" \
      --model "$model"
    ;;
  tts)
    base_url="$(service_base_url)"
    model="$(service_model_name)"
    source_profile
    "$BASE_VENV/bin/python" "$ROOT_DIR/clients/audio/tts_test.py" \
      --base-url "$base_url" \
      --model "$model" \
      --voice "${VOICE:-default}"
    ;;
  voice-assistant)
    source_profile
    "$BASE_VENV/bin/python" "$ROOT_DIR/clients/audio/pipeline_test.py" \
      --stt-base-url "${STT_BASE_URL:?STT_BASE_URL is required}" \
      --stt-model "${STT_MODEL:?STT_MODEL is required}" \
      --llm-base-url "${ELIZA_SMALL_BASE_URL:?ELIZA_SMALL_BASE_URL is required}" \
      --llm-model "${ELIZA_SMALL_MODEL:?ELIZA_SMALL_MODEL is required}" \
      --tts-base-url "${TTS_BASE_URL:?TTS_BASE_URL is required}" \
      --tts-model "${TTS_MODEL:?TTS_MODEL is required}" \
      --tts-voice "${TTS_VOICE:-default}"
    ;;
  vocode-bridge)
    source_profile
    "$BASE_VENV/bin/python" "$ROOT_DIR/clients/audio/vocode_bridge_test.py" \
      --url "ws://127.0.0.1:${PORT:-8021}/ws"
    ;;
  *)
    base_url="$(service_base_url)"
    model="$(service_model_name)"
    "$BASE_VENV/bin/python" "$ROOT_DIR/clients/openai/smoke_test.py" \
      --base-url "$base_url" \
      --model "$model"
    ;;
esac
